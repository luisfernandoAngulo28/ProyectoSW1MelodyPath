# Email (producción)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=tu@email.com
EMAIL_HOST_PASSWORD=tu_password

# Claude API (Anthropic) — para lecciones personalizadas con IA
